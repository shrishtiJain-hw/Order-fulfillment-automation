{
  "info": {
    "_postman_id": "b4646846-638b-4e10-b1c8-c584617a3448",
    "name": "Fulfillment Lifecycle",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51663121",
    "_collection_link": "https://go.postman.co/collection/51663121-b4646846-638b-4e10-b1c8-c584617a3448?source=collection_link"
  },
  "item": [
    {
      "name": "Find Open Orders",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let response = pm.response.json();",
              "let groups = response.grouped && response.grouped.orderItemShipGroupIdentifier && response.grouped.orderItemShipGroupIdentifier.groups;",
              "",
              "if (!groups || groups.length === 0) {",
              "    console.log(\"No open orders found.\");",
              "    pm.environment.set(\"shipmentGroups\", \"[]\");",
              "    pm.environment.set(\"groupIndex\", 0);",
              "    postman.setNextRequest(null);",
              "} else {",
              "    let shipmentGroups = [];",
              "    groups.forEach(group => {",
              "        let docs = group.doclist.docs;",
              "        let orderItems = [];",
              "",
              "        docs.forEach(doc => {",
              "            orderItems.push({",
              "                orderId: doc.orderId,",
              "                orderItemSeqId: doc.orderItemSeqId,",
              "                shipGroupSeqId: doc.shipGroupSeqId,",
              "                productId: doc.productId,",
              "                quantity: doc.quantity",
              "            });",
              "        });",
              "",
              "        shipmentGroups.push({",
              "            orderId: docs[0].orderId,",
              "            shipGroupSeqId: docs[0].shipGroupSeqId,",
              "            existingShipmentId: docs[0].shipmentId || null,",
              "            orderItems: orderItems",
              "        });",
              "    });",
              "",
              "    pm.environment.set(\"shipmentGroups\", JSON.stringify(shipmentGroups));",
              "    pm.environment.set(\"groupIndex\", 0);",
              "    console.log(\"Groups Found:\", shipmentGroups.length);",
              "    postman.setNextRequest(\"Pick\");",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"json\": {\n        \"params\": {\n            \"rows\": \"10\",\n            \"sort\": \"orderDate asc\",\n            \"q.op\": \"AND\",\n            \"start\": 0,\n            \"group\": true,\n            \"group.field\": \"orderItemShipGroupIdentifier\",\n            \"group.limit\": 1000,\n            \"group.ngroups\": true\n        },\n        \"query\": \"(*:*)\",\n        \"filter\": \"docType: ORDER AND -shipmentMethodTypeId: (STOREPICKUP OR POS_COMPLETED) AND orderStatusId: ORDER_APPROVED AND orderTypeId: SALES_ORDER AND productStoreId: {{productStoreId}} AND facilityId: {{facilityId}} AND ((*:* -fulfillmentStatus: [* TO *]) OR fulfillmentStatus:Created)\"\n    }\n}\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseSolrUrl}}",
          "host": [
            "{{baseSolrUrl}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Pick",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let groupsStr = pm.environment.get(\"shipmentGroups\");",
              "let groups = groupsStr ? JSON.parse(groupsStr) : [];",
              "let index = parseInt(pm.environment.get(\"groupIndex\")) || 0;",
              "",
              "if (groups && index < groups.length) {",
              "    let currentGroup = groups[index];",
              "    pm.environment.set(\"orderId\", currentGroup.orderId);",
              "    pm.environment.set(\"shipGroupSeqId\", currentGroup.shipGroupSeqId);",
              "    pm.environment.set(\"currentOrderItems\", JSON.stringify(currentGroup.orderItems));",
              "",
              "    // If this group already has a shipment, skip Pick and go straight to Pack",
              "    if (currentGroup.existingShipmentId) {",
              "        console.log(\"Order already has shipment \" + currentGroup.existingShipmentId + \", skipping Pick -> going to Pack\");",
              "        pm.environment.set(\"shipmentId\", currentGroup.existingShipmentId);",
              "        postman.setNextRequest(\"Pack\");",
              "    }",
              "} else {",
              "    console.log(\"Pre-request Pick Error: Invalid shipmentGroups or groupIndex out of range. Index: \" + index);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let response = pm.response.json();",
              "if (response.shipmentIds && response.shipmentIds.length > 0) {",
              "    pm.environment.set(\"picklistId\", response.picklistId);",
              "    pm.environment.set(\"shipmentId\", response.shipmentIds[0]);",
              "    console.log(\"Shipment Created:\", response.shipmentIds[0]);",
              "    postman.setNextRequest(\"Pack\");",
              "} else {",
              "    console.log(\"Pick wave creation failed for this group, skipping to next group.\", response);",
              "    // Advance to next group",
              "    let groupsStr = pm.environment.get(\"shipmentGroups\");",
              "    let groups = groupsStr ? JSON.parse(groupsStr) : [];",
              "    let index = parseInt(pm.environment.get(\"groupIndex\")) || 0;",
              "    index++;",
              "    pm.environment.set(\"groupIndex\", index);",
              "    if (index < groups.length) {",
              "        console.log(\"Skipping to next group. Index: \" + index + \"/\" + groups.length);",
              "        postman.setNextRequest(\"Pick\");",
              "    } else {",
              "        console.log(\"All groups processed (some may have been skipped).\");",
              "        postman.setNextRequest(null);",
              "    }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"packageName\": \"A\",\n  \"facilityId\": \"{{facilityId}}\",\n  \"shipmentMethodTypeId\": \"STANDARD\",\n  \"statusId\": \"PICKLIST_ASSIGNED\",\n  \"pickers\": [\n    {\n      \"partyId\": \"{{pickerPartyId}}\",\n      \"roleTypeId\": \"WAREHOUSE_PICKER\"\n    }\n  ],\n  \"orderItems\": {{currentOrderItems}}\n}\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{basePoortiUrl}}/createOrderFulfillmentWave",
          "host": [
            "{{basePoortiUrl}}"
          ],
          "path": [
            "createOrderFulfillmentWave"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Pack",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();",
              "if (response.packedShipmentId) {",
              "    pm.environment.set(\"packedShipmentId\", response.packedShipmentId);",
              "    console.log(\"Shipment Packed:\", response.packedShipmentId);",
              "    postman.setNextRequest(\"Ship\");",
              "} else {",
              "    console.log(\"Pack step failed: no packedShipmentId in response.\", response);",
              "    postman.setNextRequest(null);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shipmentId\": \"{{shipmentId}}\",\n  \"orderId\": \"{{orderId}}\",\n  \"facilityId\": \"{{facilityId}}\",\n  \"rejectedOrderItems\": [],\n  \"shipmentPackageContents\": []\n}\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{basePoortiUrl}}/shipments/{{shipmentId}}/pack",
          "host": [
            "{{basePoortiUrl}}"
          ],
          "path": [
            "shipments",
            "{{shipmentId}}",
            "pack"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Ship",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let groupsStr = pm.environment.get(\"shipmentGroups\");",
              "let groups = groupsStr ? JSON.parse(groupsStr) : [];",
              "let index = parseInt(pm.environment.get(\"groupIndex\")) || 0;",
              "",
              "console.log(\"Shipment Shipped:\", pm.environment.get(\"shipmentId\"));",
              "",
              "index++;",
              "pm.environment.set(\"groupIndex\", index);",
              "",
              "if (index < groups.length) {",
              "    console.log(`Looping back to Pick. Next index: ${index}/${groups.length}`);",
              "    postman.setNextRequest(\"Pick\");",
              "} else {",
              "    console.log(\"All Fulfillment Completed\");",
              "    postman.setNextRequest(null);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"shipmentId\": \"{{shipmentId}}\"\n}\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{basePoortiUrl}}/shipments/{{shipmentId}}/ship",
          "host": [
            "{{basePoortiUrl}}"
          ],
          "path": [
            "shipments",
            "{{shipmentId}}",
            "ship"
          ]
        }
      },
      "response": []
    }
  ]
}